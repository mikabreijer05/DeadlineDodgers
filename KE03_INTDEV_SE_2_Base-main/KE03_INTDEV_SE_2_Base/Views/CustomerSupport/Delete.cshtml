@model KE03_INTDEV_SE_2_Base.Models.CustomerServiceTicket

@{
    ViewData["Title"] = "Delete ticket";
}

<div class="container mt-4">
    <h1 class="h3">Delete ticket</h1>

    <h4>Are you sure you want to delete this ticket?</h4>
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">@Model.Title</h5>
            <p class="card-text">Customer: @(Model.Customer?.Name ?? "-")</p>
            <p class="card-text"><small class="text-muted">Created: @Model.DateCreated.ToLocalTime().ToString("g")</small></p>
        </div>
    </div>

    <form action="@Url.Action("Delete", "Support", new { id = Model.Id })" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-controller="Support" asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>
