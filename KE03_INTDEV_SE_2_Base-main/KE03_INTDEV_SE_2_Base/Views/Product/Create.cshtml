@model KE03_INTDEV_SE_2_Base.Models.Product

@{
    ViewData["Title"] = "Create Product";
}

<h1>Nieuw Product</h1>

<form asp-action="Create" method="post">

    <!-- Product Id (hidden for consistency with Edit structure) -->
    <input type="hidden" asp-for="Id" />

    <!-- Product Name -->
    <div>
        <label asp-for="Name"></label>
        <input asp-for="Name" />
    </div>

    <!-- Product Price -->
    <div>
        <label asp-for="Price"></label>
        <input asp-for="Price" />
    </div>

    <!-- Product Description -->
    <div>
        <label asp-for="Description"></label>
        <input asp-for="Description" />
    </div>

    <!-- Product Image -->
    <div>
        <label asp-for="ImageUrl"></label>
        <input asp-for="ImageUrl" />
    </div>

    <!-- Product Quantity -->
    <div>
        <label asp-for="Quantity"></label>
        <input asp-for="Quantity" />
    </div>

    <!-- DDC Id -->
    <div>
        <label asp-for="DDCId"></label>
        <input asp-for="DDCId" />
    </div>

    <!-- Delivery Time -->
    <div>
        <label asp-for="DeliveryTime"></label>
        <input asp-for="DeliveryTime" />
    </div>

    <!-- Discount Id -->
    <div>
        <label asp-for="DiscountId"></label>
        <input asp-for="DiscountId" />
    </div>

    <!-- Product Cost -->
    <div>
        <label asp-for="Cost"></label>
        <input asp-for="Cost" />
    </div>

    <!-- Product Dimensions -->
    <div>
        <label asp-for="Dimensions"></label>
        <input asp-for="Dimensions" />
    </div>

    <!-- Category -->
    <div>
        <label asp-for="CategoryId"></label>
        <input asp-for="CategoryId" />
    </div>

    <button type="submit">Save</button>

    @* IMPROVED: consistent back navigation *@
    <a href="/Product/Index" class="matrix-btn">
        ← Terug
    </a>

</form>