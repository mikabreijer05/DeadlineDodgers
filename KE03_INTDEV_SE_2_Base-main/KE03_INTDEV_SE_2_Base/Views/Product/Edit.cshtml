@model KE03_INTDEV_SE_2_Base.Models.Product

@{
    ViewData["Title"] = "Edit Product";
}

<link rel="stylesheet" href="~/css/products.css" />

<div class="product-layout">

    <!-- SIDEBAR: navigation and quick actions -->
    <!-- WHAT: provides navigation between pages -->
    <!-- WHY: keeps user inside product management flow -->
    <aside class="sidebar">

        <div class="sidebar-header">
            <span class="sidebar-label">Matrix</span>

            <div class="sidebar-title-row">
                <h2>Producten</h2>
            </div>

            <a href="/Product/Create" class="matrix-btn">+ Nieuw Product</a>
            <a href="/Product/Index" class="matrix-btn">← Overzicht</a>
        </div>

    </aside>

    <!-- EDIT PANEL -->
    <!-- WHAT: displays selected product for editing -->
    <!-- WHY: separates navigation (left) and editing (right) -->
    <main class="editor-panel">

        <div class="editor-header">

            <div class="editor-title">
                <small>&gt; PRODUCT_EDIT</small>
                <h1>@Model.Name</h1>
            </div>

            <!-- deletes current product -->
            <!-- WHY: direct action shortcut for admin workflow -->
            <a href="/Product/Delete/@Model.Id"
               class="delete-btn"
               onclick="return confirm('Verwijderen?')">
                Verwijderen
            </a>

        </div>

        <!-- EDIT FORM -->
        <!-- WHAT: sends updated product data to controller -->
        <!-- WHY: binds directly to Product model via MVC binding -->
        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <div class="editor-card">

                <!-- image field -->
                <label>Image URL</label>
                <input asp-for="ImageUrl" />

                <div class="form-grid">

                    <div><label>Name</label><input asp-for="Name" /></div>
                    <div><label>Price</label><input asp-for="Price" /></div>
                    <div><label>Cost</label><input asp-for="Cost" /></div>
                    <div><label>Quantity</label><input asp-for="Quantity" /></div>
                    <div><label>DDCId</label><input asp-for="DDCId" /></div>
                    <div><label>Delivery</label><input asp-for="DeliveryTime" /></div>
                    <div><label>Discount</label><input asp-for="DiscountId" /></div>

                    <div class="full-width">
                        <label>Description</label>
                        <textarea asp-for="Description"></textarea>
                    </div>

                    <div class="full-width">
                        <label>Dimensions</label>
                        <input asp-for="Dimensions" />
                    </div>

                </div>

                <button class="save-btn" type="submit">
                    Save Changes
                </button>

                <div asp-validation-summary="All"
                     class="validation-summary-errors"></div>

            </div>
        </form>

    </main>
</div>