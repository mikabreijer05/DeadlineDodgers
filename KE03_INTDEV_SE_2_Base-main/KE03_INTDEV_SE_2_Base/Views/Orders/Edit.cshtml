@model KE03_INTDEV_SE_2_Base.Models.Order

@{
    ViewData["Title"] = "Edit Order";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <h1>@ViewData["Title"]</h1>

            <form asp-action="Edit" method="post">
                <div class="card">
                    <div class="card-body">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="OrderDate" class="form-label">Order Date</label>
                            <input asp-for="OrderDate" class="form-control" type="datetime-local" />
                            <span asp-validation-for="OrderDate" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CustomerId" class="form-label">Customer ID</label>
                            <input asp-for="CustomerId" class="form-control" type="number" />
                            <span asp-validation-for="CustomerId" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}