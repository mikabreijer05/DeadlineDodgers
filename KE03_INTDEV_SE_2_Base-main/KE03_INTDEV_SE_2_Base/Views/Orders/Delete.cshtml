@model KE03_INTDEV_SE_2_Base.Models.Order

@{
    ViewData["Title"] = "Delete Order";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <h1>@ViewData["Title"]</h1>

            <div class="alert alert-danger" role="alert">
                <strong>Are you sure you want to delete this order?</strong>
            </div>

            <div class="card mb-3">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Order ID</dt>
                        <dd class="col-sm-9">@Model.Id</dd>

                        <dt class="col-sm-3">Customer ID</dt>
                        <dd class="col-sm-9">@Model.CustomerId</dd>

                        <dt class="col-sm-3">Order Date</dt>
                        <dd class="col-sm-9">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</dd>
                    </dl>
                </div>
            </div>

            <form asp-action="DeleteConfirmed" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>