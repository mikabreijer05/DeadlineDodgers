@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<section>
    <h1>Producten</h1>

    <div class="product-card">
        @foreach (var product in Model.Products)
        {
            <div class="product-card">
                <h3>@product.Name</h3>
                <p>€@product.Price</p>
            </div>
        }
    </div>

</section>



