@page
@model KE03_INTDEV_SE_1_Base.Pages.OnderdelenModel
@{
    ViewData["Title"] = "Onderdelen";
}

<section>
    @if (!string.IsNullOrWhiteSpace(Model.Q))
    {
        <h1>Onderdelen zoeken naar "@Model.Q"</h1>
    }
    else
    {
        <h1>ALLE ONDERDELEN</h1>
    }

    <form method="get" class="product-filter-form">
        <div class="filter-group">
            <label for="q">Zoeken</label>
            <input id="q" name="q" type="text" value="@Model.Q" placeholder="Zoek onderdeel..." />
        </div>

        <div class="filter-group">
            <label for="minPrice">Min prijs</label>
            <input id="minPrice" name="minPrice" type="number" min="0" step="0.01" value="@Model.MinPrice" placeholder="€ min" />
        </div>

        <div class="filter-group">
            <label for="maxPrice">Max prijs</label>
            <input id="maxPrice" name="maxPrice" type="number" min="0" step="0.01" value="@Model.MaxPrice" placeholder="€ max" />
        </div>

        <div class="filter-actions">
            <button type="submit" class="filter-button">Filteren</button>
            <a asp-page="/Onderdelen" class="filter-reset-button">Reset</a>
        </div>
    </form>

    @if (!Model.Products.Any())
    {
        <p class="no-products-message">Geen onderdelen gevonden.</p>
    }
    else
    {
        <div class="product-grid">
            @foreach (var product in Model.Products)
            {
                <div class="product-card"
                     onclick="window.location.href='@Url.Page("/ProductPagina", new { id = product.Id })'">
                    <img src="@product.ImageUrl" alt="@product.Name">
                    <h3>@product.Name</h3>
                    <p>€@product.Price</p>
                    <button class="add-btn"
                            data-product-id="@product.Id"
                            data-product-name="@product.Name"
                            data-product-price="@product.Price"
                            onclick="event.stopPropagation()">
                        🛒 in winkelwagen
                    </button>
                </div>
            }
        </div>
    }
</section>