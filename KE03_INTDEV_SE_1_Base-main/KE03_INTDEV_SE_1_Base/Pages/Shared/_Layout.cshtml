@inherits Microsoft.AspNetCore.Mvc.Razor.RazorPage<dynamic>
<!DOCTYPE html>
<html lang="en">


    <!--Inheritance toegevoegd om-->
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KE03_INTDEV_SE_1_Base</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/KE03_INTDEV_SE_1_Base.styles.css" />
    <script src="~/js/site.js" defer></script>
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>
    <header>
        <!-- Header top row: logo, search and icons -->
        <div class="navbar-header-content">
            <a class="navbar-brand" asp-area="" asp-page="/Index">
                Matrix Market
            </a>
            <div class="search-container">
                <input type="text" placeholder="Zoeken..." />
            </div>
            <div class="nav-icons">
                <a class="nav-link" asp-page="/Login" title="Inloggen">
                    <i class="fa-solid fa-user"></i>
                </a>
                <a class="nav-link" href="/Cart" title="Winkelmandje" style="position:relative;">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span id="cartCount" style="position:absolute; top:-10px; right:-12px; background:#20ff62; color:#000; font-size:0.92rem; font-weight:bold; padding:2px 7px; border-radius:14px;"></span>
                </a>
            </div>
        </div>
        <!-- Category navigation bar, horizontal, below nav row -->
        <div class="category-bar">
            <a href="#" class="active">HOME</a>
            <a href="#">REALITY</a>
            <a href="#">ILLUSION</a>
            <a href="#">HARDWARE</a>
            <a href="#">ACCESSORIES</a>
            <a href="#">APPAREL</a>
            <a href="#">VEHICLES</a>
            <a href="#">SOFTWARE</a>
        </div>
        <!-- Green separator line below header -->
        <hr class="header-separator" />
    </header>

    <!-- Main content area -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Toast for Add to Cart notifications Noaw -->
    <div id="toast" style="
        display:none;
        position:fixed;
        bottom:40px;
        left:50%;
        transform:translateX(-50%);
        background:#20ff62;
        color:black;
        font-family:monospace;
        font-weight:bold;
        font-size:1.1rem;
        padding:14px 40px;
        border-radius:18px;
        z-index: 9999;
        box-shadow: 0 0 24px #20ff6299;
        transition: opacity 0.3s;">
    </div>

    <!-- Footer -->
    <footer class="footer text-muted">
        <div class="container">

            <p>&copy; 2025 - KE03_INTDEV_SE_1_Base</p>

            <div class="footer-buttons">
                <a asp-page="/OverOns" class="btn btn-outline-light">
                    Over Ons
                </a>

                <a asp-page="/Privacy" class="btn btn-outline-light">
                    Privacy
                </a>

                <a asp-page="/Klantenservice" class="btn btn-outline-light">
                    Klantenservice
                </a>
            </div>

        </div>
    </footer>


    <!-- Bootstrap scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>