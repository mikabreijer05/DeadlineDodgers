@inherits Microsoft.AspNetCore.Mvc.Razor.RazorPage<dynamic>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KE03_INTDEV_SE_1_Base</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/KE03_INTDEV_SE_1_Base.styles.css" />
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>
    <header>
        <!-- Header top row: logo, search and icons -->
        <div class="navbar-header-content">
            <a class="navbar-brand" asp-area="" asp-page="/Index">
                Matrix Market
            </a>
            <div class="search-container">
                <input type="text" placeholder="Zoeken..." />
            </div>
            <div class="nav-icons">
                <a class="nav-link" asp-page="/Login" title="Inloggen">
                    <i class="fa-solid fa-user"></i>
                </a>
                <a class="nav-link" asp-page="/Cart" title="Winkelmandje">
                    <i class="fa-solid fa-cart-shopping"></i>
                </a>
            </div>
        </div>
        <!-- Category navigation bar, horizontal, below nav row -->
        <div class="category-bar">
            <a href="#" class="active">HOME</a>
            <a href="#">REALITY</a>
            <a href="#">ILLUSION</a>
            <a href="#">HARDWARE</a>
            <a href="#">ACCESSORIES</a>
            <a href="#">APPAREL</a>
            <a href="#">VEHICLES</a>
            <a href="#">SOFTWARE</a>
        </div>
        <!-- Green separator line below header -->
        <hr class="header-separator" />
    </header>

    <!-- Main content area -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - KE03_INTDEV_SE_1_Base - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>