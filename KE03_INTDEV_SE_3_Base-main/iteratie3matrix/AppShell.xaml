<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="iteratie3matrix.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:iteratie3matrix.Pages"
    xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.SegmentedControl;assembly=Syncfusion.Maui.Toolkit"
    Title="iteratie3matrix">

    <!-- START PAGE (Orders first) -->
    <ShellContent
        Title="Orders"
        ContentTemplate="{DataTemplate pages:OrderListPage}"
        Route="orders" />

    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate pages:MainPage}"
        Route="main" />

    <ShellContent
        Title="Manage Meta"
        ContentTemplate="{DataTemplate pages:ManageMetaPage}"
        Route="manage" />

    <!-- DETAIL ROUTE (THIS WAS MISSING / WRONG BEFORE) -->
    <ShellContent
        Route="order"
        ContentTemplate="{DataTemplate pages:OrderDetailPage}" />

    <Shell.FlyoutFooter>
        <Grid Padding="15">
            <sf:SfSegmentedControl x:Name="ThemeSegmentedControl">
                <sf:SfSegmentedControl.ItemsSource>
                    <x:Array Type="{x:Type sf:SfSegmentItem}">
                        <sf:SfSegmentItem ImageSource="{StaticResource IconLight}" />
                        <sf:SfSegmentItem ImageSource="{StaticResource IconDark}" />
                    </x:Array>
                </sf:SfSegmentedControl.ItemsSource>
            </sf:SfSegmentedControl>
        </Grid>
    </Shell.FlyoutFooter>

</Shell>