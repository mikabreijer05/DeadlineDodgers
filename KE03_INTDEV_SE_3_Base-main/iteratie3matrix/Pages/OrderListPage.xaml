<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:pageModels="clr-namespace:iteratie3matrix.PageModels"
    xmlns:models="clr-namespace:iteratie3matrix.Models"
    x:Class="iteratie3matrix.Pages.OrderListPage"
    x:DataType="pageModels:OrderListPageModel"
    Title="Orders">

    <Grid Padding="20">

        <CollectionView ItemsSource="{Binding Orders}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Order">

                    <Border Padding="10" Margin="0,0,0,10">

                        <VerticalStackLayout Spacing="5">

                            <Label
                                FontSize="22"
                                Text="{Binding OrderId,
                                StringFormat='Order #{0}'}" />

                            <Label
                                Text="{Binding OrderDate}" />

                        </VerticalStackLayout>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- DEBUG (TEMP) -->
        <Label
            Text="{Binding Orders.Count}"
            TextColor="White"
            HorizontalOptions="Center"
            VerticalOptions="End" />

    </Grid>

</ContentPage>